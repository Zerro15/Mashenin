TZ=Asia/Yekaterinburg
DISABLE_IPV6=true

# DuckDNS updater
DUCKDNS_SUBDOMAINS=your-subdomain
DUCKDNS_TOKEN=your-duckdns-token
DUCKDNS_PUBLISH_IP=203.0.113.10
DUCKDNS_PUBLISH_IP_FILE=/state/public-ip.txt
DUCKDNS_INTERVAL_SECONDS=300

# Planned external hostnames
MASHENIN_BASE_DOMAIN=your-subdomain.duckdns.org
MASHENIN_WEB_FQDN=your-subdomain.duckdns.org
MASHENIN_API_PATH=/api

# Local upstreams that Nginx Proxy Manager will forward to
MASHENIN_WEB_TARGET_HOST=host.docker.internal
MASHENIN_WEB_TARGET_PORT=3001
MASHENIN_API_TARGET_HOST=host.docker.internal
MASHENIN_API_TARGET_PORT=4000
